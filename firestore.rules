rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bus status collection - allows real-time sync for all users
    match /busStatus/{busId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Bus stops collection - static data
    match /busStops/{stopId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
